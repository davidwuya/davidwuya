---
import { getCollection } from "astro:content";
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import ArrowCard from "@components/ArrowCard.astro";
import Link from "@components/Link.astro";
import { dateRange } from "@lib/utils";
import { SITE, HOME, SOCIALS } from "@consts";

const projects = (await getCollection("projects"))
  .filter(project => !project.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0,SITE.NUM_PROJECTS_ON_HOMEPAGE);

const allwork = (await getCollection("work"))
  .sort((a, b) => new Date(b.data.dateStart).valueOf() - new Date(a.data.dateStart).valueOf())
  .slice(0,SITE.NUM_WORKS_ON_HOMEPAGE);

const work = await Promise.all(
  allwork.map(async (item) => {
    const { Content } = await item.render();
    return { ...item, Content };
  })
);

---

<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <h4 class="animate font-semibold text-black dark:text-white">
      Hi, I'm David <span class="text-xl">👋🏻</span> 
    </h4>
    <div class="space-y-16">
      <section>
        <article class="space-y-4">
          <p class="animate">
            I am a hardware engineer with a passion for building products that help push the boundaries of technology.
          </p>
        </article>
      </section>


      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="font-semibold text-black dark:text-white">
            Work Experience
          </h5>
          <Link href="/work">
            See all work
          </Link>
        </div>
        <ul class="flex flex-col space-y-4">
          {work.map(entry => (
            <li>
              <div class="text-sm opacity-75">
                {dateRange(entry.data.dateStart, entry.data.dateEnd)}
              </div>
              <div class="font-semibold text-black dark:text-white">
                {entry.data.companyURL ? (
                  <a href={entry.data.companyURL} target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 decoration-black/15 dark:decoration-white/30 hover:decoration-black/50 dark:hover:decoration-white/50 transition-colors">
                    {entry.data.company}
                  </a>
                ) : (
                  entry.data.company
                )}
              </div>
              <div class="text-sm opacity-75">
                {entry.data.role}
              </div>
              <article>
                <entry.Content />
              </article>
            </li>
          ))}
        </ul>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="font-semibold text-black dark:text-white">
            Recent projects
          </h5>
          <Link href="/projects">
            See all projects
          </Link>
        </div>
        <ul class="flex flex-col gap-4">
          {projects.map(project => (
            <li>
              <ArrowCard entry={project} />
            </li>
          ))}
        </ul>
      </section>

      <section class="animate space-y-4">
        <h5 class="font-semibold text-black dark:text-white">
          Let's Connect
        </h5>
        <article>
          <p>
            If you want to get in touch with me about something or just to say hi,
            reach out on social media or send me an email.
          </p>
        </article>
        <ul class="flex flex-wrap gap-2">
          {SOCIALS.map(SOCIAL => (
            <li class="flex gap-x-2 text-nowrap">
              <Link href={SOCIAL.HREF} external aria-label={`${SITE.NAME} on ${SOCIAL.NAME}`}>
                {SOCIAL.NAME}
              </Link>
              {"/"}
            </li>
          ))}
          <li id="email-container">
            <button
              id="reveal-email-btn"
              class="inline-block underline underline-offset-2 decoration-black/15 dark:decoration-white/30 hover:decoration-black/25 hover:dark:decoration-white/50 text-current hover:text-black hover:dark:text-white transition-colors duration-300 ease-in-out cursor-pointer"
            >
              reveal email
            </button>
            <div id="hcaptcha-widget" class="mt-2"></div>
          </li>
        </ul>
      </section>
    </div>
  </Container>

  <script is:inline>
    window.onCaptchaVerify = async function(token) {
      var container = document.getElementById("email-container");
      container.innerHTML = '<span class="opacity-50">Verifying...</span>';

      try {
        var res = await fetch("/api/verify-captcha", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ token: token }),
        });
        var data = await res.json();

        if (data.email) {
          container.innerHTML =
            '<a href="mailto:' + data.email + '" ' +
            'class="inline-block underline underline-offset-2 decoration-black/15 dark:decoration-white/30 hover:decoration-black/25 hover:dark:decoration-white/50 text-current hover:text-black hover:dark:text-white transition-colors duration-300 ease-in-out">' +
            data.email + '</a>';
        } else {
          container.innerHTML = '<span class="text-red-500">Verification failed. Please refresh and try again.</span>';
        }
      } catch (e) {
        container.innerHTML = '<span class="text-red-500">Something went wrong. Please try again.</span>';
      }
    };

    window.onHcaptchaLoad = function() {};

    function attachRevealHandler() {
      window._hcaptchaWidgetId = null;
      var btn = document.getElementById("reveal-email-btn");
      if (btn) {
        btn.addEventListener("click", function() {
          if (typeof hcaptcha === "undefined") {
            alert("hCaptcha is still loading. Please try again in a moment.");
            return;
          }
          if (window._hcaptchaWidgetId === null) {
            window._hcaptchaWidgetId = hcaptcha.render("hcaptcha-widget", {
              sitekey: "8adad5ee-dab2-4ec0-a9a6-be7804daabf0",
              callback: "onCaptchaVerify",
              theme: document.documentElement.classList.contains("dark") ? "dark" : "light",
            });
          }
        });
      }
    }

    document.addEventListener("DOMContentLoaded", attachRevealHandler);
    document.addEventListener("astro:after-swap", attachRevealHandler);
  </script>
  <script is:inline src="https://js.hcaptcha.com/1/api.js?onload=onHcaptchaLoad&render=explicit" async defer></script>
</PageLayout>
